{
  "name": "ag-grid-worker-sandbox",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.22",
  "workspaces": [
    "apps/demo",
    "packages/ag-grid-translator",
    "packages/sqlite-store"
  ],
  "scripts": {
    "prepare": "bunx effect-language-service patch",
    "dev": "turbo dev --filter=@sandbox/demo",
    "dev:demo": "turbo dev --filter=@sandbox/demo",
    "build": "turbo build",
    "build:demo": "turbo build --filter=@sandbox/demo",
    "test": "turbo test",
    "test:watch": "vitest --root .",
    "typecheck": "turbo typecheck",
    "check": "turbo run build typecheck test"
  },
  "devDependencies": {
    "@effect/language-service": "^0.81.0",
    "@effect/vitest": "4.0.0-beta.36",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "effect-solutions": "^0.5.2",
    "jsdom": "^27.0.0",
    "turbo": "^2.8.19",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "effect": "4.0.0-beta.36"
  }
}
